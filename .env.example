# Discord
DISCORD_TOKEN=your_discord_bot_token_here
# Optional: your server ID (right-click server name -> Copy ID) so slash commands appear immediately
GUILD_ID=

# Canvas API
CANVAS_TOKEN=your_canvas_access_token_here
CANVAS_BASE_URL=https://canvas.instructure.com/api/v1

# Optional: comma-separated course IDs. If empty, bot fetches from GET /users/self/courses
CANVAS_COURSE_IDS=

# Discord channel IDs (right-click channel -> Copy ID, with Developer Mode on)
CHANNEL_NEWS_ID=
CHANNEL_PRAZOS_ID=
CHANNEL_PREFERENCIAS_ID=

# Polling
POLL_INTERVAL_MINUTES=15
REMINDER_DAYS_BEFORE=2

# News: daily check at this time (default 18:00)
NEWS_CHECK_HOUR=18
NEWS_CHECK_MINUTE=0

# Cargos de preferência de desenvolvimento (ID do cargo no Discord)
ROLE_PREF_PROGRAMACAO=
ROLE_PREF_ARTE2D=
ROLE_PREF_ARTE3D=
ROLE_PREF_ANIMACAO=
ROLE_PREF_MUSICA=
ROLE_PREF_GAME_DESIGN=
